# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# LINE Notify (group nurse notifications)
LINE_NOTIFY_TOKEN=

# SlipOK
SLIPOK_API_KEY=
SLIPOK_ENDPOINT=https://api.slipok.com/api/line/apikey/YOUR_KEY

# Firebase
FIREBASE_PROJECT_ID=
# Defaults to {FIREBASE_PROJECT_ID}.appspot.com if blank
FIREBASE_STORAGE_BUCKET=
# Path to service account JSON for local dev.
# On Cloud Run this is NOT needed — ADC is used automatically.
GOOGLE_APPLICATION_CREDENTIALS=

# Clinic (one LINE OA = one clinic for MVP)
CLINIC_ID=
LIFF_URL=https://liff.line.me/YOUR_LIFF_ID

# Cloud Scheduler shared secret for POST /internal/remind
# Set to a secure random string in production. Leave empty to skip auth in dev.
SCHEDULER_SECRET=
