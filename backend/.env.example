# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# LINE Notify (group nurse notifications)
LINE_NOTIFY_TOKEN=

# SlipOK
SLIPOK_API_KEY=
SLIPOK_ENDPOINT=https://api.slipok.com/api/line/apikey/YOUR_KEY

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/mornut

# JWT — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Clinic (one LINE OA = one clinic for MVP)
CLINIC_ID=clinic-001
LIFF_URL=https://liff.line.me/YOUR_LIFF_ID

# Cloud Scheduler shared secret for POST /internal/remind
# Set to a secure random string in production. Leave empty to skip auth in dev.
SCHEDULER_SECRET=

# Set to true locally to enable the /admin/line-oa/dev-connect bypass (never in production)
DEBUG_MODE=false

# CORS allowed origins — comma-separated list
# In dev, localhost:5173 is already included by default.
# In production, add your frontend domain here:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
