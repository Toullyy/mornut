rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Clinics ──────────────────────────────────────────────────────────
    match /clinics/{clinicId} {
      allow read, write: if isAdminOf(clinicId);

      match /services/{serviceId} {
        allow read: if request.auth != null;
        allow write: if isAdminOf(clinicId);
      }

      match /quotas/{date} {
        allow read: if request.auth != null;
        allow write: if isAdminOf(clinicId);
      }

      match /slots/{date} {
        allow read: if request.auth != null;
        allow write: if isAdminOf(clinicId);
      }

      // Admin membership sub-collection (used by isAdminOf)
      match /admins/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // managed server-side only
      }
    }

    // ── Bookings ─────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Patient: create own booking
      allow create: if request.auth != null
        && request.resource.data.patientLineId == request.auth.uid;

      // Patient: read / update own booking
      allow read, update: if request.auth != null
        && resource.data.patientLineId == request.auth.uid;

      // Admin: full access to bookings in their clinic
      allow read, write: if request.auth != null
        && isAdminOf(resource.data.clinicId);
    }

    // ── Patients ─────────────────────────────────────────────────────────
    match /patients/{lineId} {
      allow read, write: if request.auth != null
        && request.auth.uid == lineId;
    }

    // ── Helper ───────────────────────────────────────────────────────────
    function isAdminOf(clinicId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/clinics/$(clinicId)/admins/$(request.auth.uid));
    }
  }
}
