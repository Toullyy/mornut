# LINE LIFF
VITE_LIFF_ID=

# Firebase config as a JSON string (copy from Firebase Console → Project Settings → Your apps)
# Example: VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
VITE_FIREBASE_CONFIG=

# Backend API base URL (empty = use Vite proxy in dev; set full URL in production)
VITE_API_BASE_URL=
